# Groq API (chat + extraction)
GROQ_API_KEY=
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# GROQ_EXTRACT_MODEL=llama-3.3-70b-versatile

# Hugging Face Inference API (embeddings + sentiment)
HUGGINGFACE_API_TOKEN=
# HF_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# HF_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# Local dev (default Postgres)
DATABASE_URL=postgresql://localhost/meeting_intel_development

# Supabase on Render: use the pooler URI as DATABASE_URL (port 6543), user like postgres.PROJECT_REF
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# On Render, use the pooler DATABASE_URL for builds too; direct :5432 often fails (IPv6). Use Session pool mode in Supabase if needed.

REDIS_URL=redis://localhost:6379/1
RAILS_MASTER_KEY=

# =============================================================================
# Email & follow-ups (Action Mailer — config/mailer_smtp_config.rb, production.rb)
# =============================================================================
#
# Production checklist
# --------------------
# 1. Outbound SMTP: set POSTMARK_API_TOKEN (or POSTMARK_SERVER_API_TOKEN), OR set SMTP_ADDRESS
#    plus auth fields below. If none are set, production sets perform_deliveries=false (no mail sent).
# 2. MAILER_DEFAULT_HOST: public hostname for links inside mailers (defaults to example.com if unset).
# 3. SMTP_DOMAIN: HELO/sending domain; use your real domain in production (not localhost).
# 4. Solid Queue workers must run in production (same as database-backed jobs). Follow-up sends use
#    FollowupSendJob with deliver_later — without a worker, mail stays queued.
# 5. Postmark Sender Signatures: the confirming user’s email is used as From when present; each must
#    be verified, or use FOLLOWUP_FROM_EMAIL / FOLLOWUP_FROM_NAME as a verified fallback for drafts
#    with no sender_email (see config/initializers/followup.rb).
# 6. Debugging SMTP: set SMTP_RAISE_DELIVERY_ERRORS=true temporarily so failures raise and appear in logs
#    (default false swallows some delivery errors in production).
#
# Postmark (recommended): Server API token from https://account.postmarkapp.com/servers → API Tokens
# When set, host smtp.postmarkapp.com:587 and auth are applied automatically.
# POSTMARK_API_TOKEN=
# POSTMARK_SERVER_API_TOKEN=

# Generic SMTP (used only when no Postmark token is set)
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_DOMAIN=yourdomain.com
# SMTP_USER_NAME=
# SMTP_PASSWORD=
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS_AUTO=true

# Production (MAILER_DEFAULT_HOST / SMTP_RAISE_DELIVERY_ERRORS are read in config/environments/production.rb)
# MAILER_DEFAULT_HOST=yourapp.example.com
# SMTP_RAISE_DELIVERY_ERRORS=false

# Fallback From when a draft has no sender_email (legacy); also default display name
# FOLLOWUP_FROM_EMAIL=notifications@yourdomain.com
# FOLLOWUP_FROM_NAME=Meeting Intelligence Hub

# Optional tuning (config/initializers/followup.rb)
# FOLLOWUP_DEFAULT_CHANNEL=email
# FOLLOWUP_SEND_DELAY_MINUTES=0
# FOLLOWUP_AI_MAX_TOKENS=600

# -----------------------------------------------------------------------------
# Local development only
# -----------------------------------------------------------------------------
# Postmark or generic SMTP: use bin/dev so the Solid Queue worker runs, or set DEV_INLINE_JOBS=1 for a
# single process (jobs run in-process). Probe SMTP: bin/rails mail:diag
# DEV_INLINE_JOBS=1
#
# Without Postmark/SMTP, mail is written as .eml files under tmp/mail/ (delivery_method file).
#
# By default the follow-up send path uses deliver_now inside FollowupSendJob in development; set
# FOLLOWUP_DELIVER_LATER=1 to use deliver_later (separate MailDeliveryJob) like production.
# FOLLOWUP_DELIVER_LATER=1
#
# MailHog example: SMTP_ADDRESS=localhost SMTP_PORT=1025 SMTP_ENABLE_STARTTLS_AUTO=false
