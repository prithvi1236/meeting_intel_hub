<%= @meeting.title %>
<%= @meeting.meeting_date.present? ? l(@meeting.meeting_date, format: :long) : t("followup.mailers.not_applicable_date") %>

<%= t("followup.mailers.action_item_label") %>: <%= @action_item.description %>
