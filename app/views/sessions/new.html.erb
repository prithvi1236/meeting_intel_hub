<% content_for :title, "Sign in" %>
<div class="mx-auto w-full max-w-md">
  <% if alert = flash[:alert] %>
    <p class="mb-5 rounded-xl border border-[var(--mi-red)]/40 bg-[var(--mi-red)]/10 px-4 py-3 text-sm text-[var(--mi-red)]" id="alert" role="alert"><%= alert %></p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="mb-5 rounded-xl border border-[var(--mi-border)] bg-[var(--mi-surface)] px-4 py-3 text-sm" id="notice" role="status"><%= notice %></p>
  <% end %>

  <h1 class="mb-6 text-2xl font-semibold">Sign in</h1>

  <%= form_with url: session_url, scope: :session, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :email, class: "block text-sm text-[var(--mi-text-secondary)]" %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your email address", value: params.dig(:session, :email), class: "mt-1 w-full rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)] px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= form.label :password, class: "block text-sm text-[var(--mi-text-secondary)]" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "mt-1 w-full rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)] px-3 py-2 text-sm" %>
    </div>

    <%= form.submit "Sign in", class: "w-full cursor-pointer rounded-[8px] bg-[var(--mi-teal)] px-4 py-2 text-sm font-medium text-[#0f0f0f] sm:w-auto" %>

    <div class="flex flex-col gap-2 pt-2 text-sm text-[var(--mi-text-secondary)] sm:flex-row sm:flex-wrap sm:gap-4">
      <%= link_to "Forgot password?", new_password_path, class: "text-[var(--mi-teal)] underline hover:no-underline" %>
      <%= link_to "Create an account", signup_path, class: "text-[var(--mi-teal)] underline hover:no-underline" %>
    </div>
  <% end %>
</div>
