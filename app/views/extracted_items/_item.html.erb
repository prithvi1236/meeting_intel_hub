<% field_classes = "w-full rounded-[8px] border border-neutral-800 bg-neutral-900 px-3 py-2 text-sm text-white focus:border-teal-500 focus:outline-none focus:ring-1 focus:ring-teal-500" %>
<% label_classes = "block text-xs font-medium text-neutral-400" %>

<div id="<%= dom_id(item) %>" class="rounded-[12px] border border-neutral-800 bg-neutral-950 p-3" data-controller="inline-edit">
  <div data-inline-edit-target="display" class="flex items-start gap-2">
    <div class="min-w-0 flex-1">
      <p class="text-sm font-medium text-white"><%= item.description %></p>

      <div class="mt-2 flex flex-wrap gap-2 text-xs font-mono-mi text-neutral-300">
        <% if item.owner.present? %>
          <span class="rounded-full border border-neutral-800 bg-neutral-900 px-2 py-0.5"><%= item.owner %></span>
        <% end %>
        <% if item.due_date %>
          <span class="rounded-full border border-neutral-800 bg-neutral-900 px-2 py-0.5">Due <%= item.due_date.to_fs(:long) %></span>
        <% end %>
        <span class="rounded-full border border-neutral-800 bg-neutral-900 px-2 py-0.5"><%= item.status %></span>
      </div>

      <% if item.source_quote.present? %>
        <p class="mt-2 text-xs italic leading-relaxed text-neutral-400 line-clamp-3">“<%= item.source_quote %>”</p>
      <% end %>
    </div>

    <button
      type="button"
      class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-neutral-800 bg-neutral-900 text-neutral-400 transition-colors hover:border-teal-500/50 hover:bg-teal-500/10 hover:text-teal-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-500/40 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-950"
      data-action="click->inline-edit#showForm"
      aria-label="Edit item"
      title="Edit item"
    >
      <%= render "shared/mi_icon", name: :pencil, class: "h-4 w-4" %>
    </button>
  </div>

  <div data-inline-edit-target="form" class="mt-3 hidden space-y-3">
    <%= form_with model: [ project, meeting, item ] do |f| %>
      <div>
        <%= f.label :description, class: label_classes %>
        <%= f.text_area :description, rows: 3, class: "#{field_classes} mt-1" %>
      </div>

      <div>
        <%= f.label :status, class: label_classes %>
        <%= f.select :status, ExtractedItem.statuses.keys.map { |k| [k.to_s.humanize, k] }, {}, class: "#{field_classes} mt-1" %>
      </div>

      <% owner_choices = meeting.speaker_names_for_owner_picklist %>
      <% if item.owner.present? && owner_choices.exclude?(item.owner) %>
        <% owner_choices = (owner_choices + [item.owner]).uniq.sort %>
      <% end %>
      <div>
        <%= f.label :owner, "Assigned", class: label_classes %>
        <% if owner_choices.any? %>
          <%= f.select :owner,
                options_for_select([["— None —", ""]] + owner_choices.map { |n| [n, n] }, item.owner.presence),
                {},
                class: "#{field_classes} mt-1" %>
        <% else %>
          <%= f.text_field :owner, class: "#{field_classes} mt-1", autocomplete: "name", placeholder: "Name (no speakers in transcript yet)" %>
        <% end %>
      </div>
      <div>
        <%= f.label :due_date, class: label_classes %>
        <%= f.date_field :due_date, class: "#{field_classes} mt-1 mi-date-picker-on-dark" %>
      </div>

      <div class="flex items-center pt-1">
        <%= f.submit "Save", class: "rounded-[8px] bg-[#00d1b2] px-4 py-1.5 text-xs font-semibold text-neutral-950 cursor-pointer hover:bg-[#00e6c3] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#00d1b2] focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-950" %>
        <button
          type="button"
          class="ml-3 text-xs font-medium text-neutral-400 hover:text-white transition-colors focus-visible:outline-none focus-visible:underline"
          data-action="click->inline-edit#cancel"
        >
          Cancel
        </button>
      </div>
    <% end %>
  </div>
</div>
