<%= turbo_frame_tag "meeting-detail" do %>
  <div class="flex max-h-[min(85vh,720px)] min-h-[320px] flex-col gap-4">
    <div class="flex flex-wrap items-start justify-between gap-3 border-b border-[var(--mi-border)] pb-3">
      <div class="min-w-0">
        <h2 class="truncate text-lg font-semibold"><%= @meeting.title %></h2>
        <p class="mt-1 text-xs font-mono-mi text-[var(--mi-text-secondary)]">
          <%= @meeting.status %>
          <% if @meeting.meeting_date.present? %>
            · <%= @meeting.meeting_date.to_fs(:long) %>
          <% end %>
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "Full page",
              project_meeting_path(@project, @meeting),
              class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-xs",
              data: { turbo_frame: "_top" } %>
      </div>
    </div>

    <div class="grid min-h-0 flex-1 gap-4 lg:grid-cols-2">
      <section class="flex min-h-0 flex-col rounded-[10px] border border-[var(--mi-border)] bg-[var(--mi-bg)]/40" aria-label="Transcript text">
        <p class="border-b border-[var(--mi-border)] px-3 py-2 text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)]">Transcript</p>
        <div class="min-h-0 flex-1 overflow-y-auto p-3">
          <% if @transcript&.raw_content.present? %>
            <pre class="whitespace-pre-wrap break-words font-mono-mi text-xs leading-relaxed text-[var(--mi-text)]"><%= @transcript.raw_content %></pre>
          <% elsif @meeting.processing? %>
            <p class="flex items-center gap-2 text-sm text-[var(--mi-text-secondary)]">
              <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--mi-teal)]" aria-hidden="true"></span>
              Processing transcript…
            </p>
          <% else %>
            <p class="text-sm text-[var(--mi-text-secondary)]">No transcript text yet.</p>
          <% end %>
        </div>
      </section>

      <div class="flex min-h-0 flex-col gap-4 overflow-y-auto">
        <section class="rounded-[10px] border border-[var(--mi-border)] bg-[var(--mi-surface)] p-3" aria-label="Decisions and actions">
          <p class="mb-2 text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)]">Actions &amp; decisions</p>
          <%= render "meetings/extracted_items_inner", meeting: @meeting, modal: true %>
        </section>
        <section class="rounded-[10px] border border-[var(--mi-border)] bg-[var(--mi-surface)] p-3" aria-label="Sentiment">
          <%= render "meetings/sentiment_dashboard_inner", meeting: @meeting %>
        </section>
      </div>
    </div>
  </div>
<% end %>
