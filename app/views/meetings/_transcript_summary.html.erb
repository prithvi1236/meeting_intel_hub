<%= turbo_frame_tag "transcript-summary" do %>
  <% transcript = local_assigns.fetch(:transcript) { meeting.transcript } %>
  <% project_for_links = local_assigns[:project] || meeting.project %>
  <% if transcript.blank? %>
    <div class="rounded-[10px] border border-dashed border-[var(--mi-border)] bg-[var(--mi-bg)]/40 px-4 py-3 text-sm text-[var(--mi-text-secondary)]">
      No transcript uploaded yet. Add a file below to analyze this meeting.
    </div>
  <% elsif meeting.failed? && transcript.parsed_segments.blank? %>
    <div class="rounded-[10px] border border-[var(--mi-red)]/40 bg-[var(--mi-red)]/10 px-4 py-3 text-sm text-[var(--mi-red)]">
      <p class="font-medium">Transcript could not be processed</p>
      <% if meeting.processing_error.present? %>
        <p class="mt-1 text-xs opacity-90"><%= meeting.processing_error %></p>
      <% end %>
    </div>
  <% elsif transcript.parsed_segments.blank? %>
    <div class="rounded-[10px] border border-[var(--mi-border)] bg-[var(--mi-surface)] px-4 py-3">
      <p class="text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)] mb-2">Transcript summary</p>
      <div class="flex flex-wrap items-center gap-3 text-sm">
        <span class="truncate font-medium" title="<%= transcript.file_name %>"><%= transcript.file_name %></span>
        <span class="rounded-full border border-[var(--mi-border)] px-2 py-0.5 text-xs font-mono-mi text-[var(--mi-text-secondary)]">.<%= transcript.file_format %></span>
      </div>
      <p class="mt-3 flex items-center gap-2 text-sm text-[var(--mi-text-secondary)]">
        <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--mi-teal)]" aria-hidden="true"></span>
        Parsing transcript… speaker count and word total will appear here shortly.
      </p>
    </div>
  <% else %>
    <div class="rounded-[10px] border border-[var(--mi-border)] bg-[var(--mi-surface)] px-4 py-3">
      <p class="text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)] mb-3">Transcript summary</p>
      <dl class="grid gap-3 text-sm sm:grid-cols-2">
        <div>
          <dt class="text-xs text-[var(--mi-text-secondary)]">File</dt>
          <dd class="mt-0.5 font-medium truncate" title="<%= transcript.file_name %>"><%= transcript.file_name %></dd>
        </div>
        <div>
          <dt class="text-xs text-[var(--mi-text-secondary)]">Format</dt>
          <dd class="mt-0.5"><span class="rounded-full border border-[var(--mi-border)] px-2 py-0.5 text-xs font-mono-mi">.<%= transcript.file_format %></span></dd>
        </div>
        <div>
          <dt class="text-xs text-[var(--mi-text-secondary)]">Word count</dt>
          <dd class="mt-0.5 font-mono-mi"><%= number_with_delimiter(meeting.word_count.to_i) %></dd>
        </div>
        <div>
          <dt class="text-xs text-[var(--mi-text-secondary)]">Speakers identified</dt>
          <dd class="mt-0.5 font-mono-mi"><%= transcript.total_speakers.to_i %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-xs text-[var(--mi-text-secondary)]">Detected from file</dt>
          <dd class="mt-0.5">
            <% if transcript.detected_meeting_date.present? %>
              <%= transcript.detected_meeting_date.to_fs(:long) %>
            <% else %>
              <span class="text-[var(--mi-text-secondary)]">—</span>
            <% end %>
          </dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-xs text-[var(--mi-text-secondary)]">Meeting date (calendar)</dt>
          <dd class="mt-0.5">
            <% if meeting.meeting_date.present? %>
              <%= meeting.meeting_date.to_fs(:long) %>
            <% else %>
              <span class="text-[var(--mi-text-secondary)]">Not set — <%= link_to "add in edit", edit_project_meeting_path(project_for_links, meeting), class: "text-[var(--mi-teal)] hover:underline" %></span>
            <% end %>
          </dd>
        </div>
      </dl>
      <% if transcript.detected_meeting_date.present? && meeting.meeting_date.present? && transcript.detected_meeting_date != meeting.meeting_date %>
        <p class="mt-3 text-xs text-[var(--mi-text-secondary)] border-t border-[var(--mi-border)] pt-3">
          The date in the file differs from the meeting’s calendar date. You can <%= link_to "update the meeting", edit_project_meeting_path(project_for_links, meeting), class: "text-[var(--mi-teal)] hover:underline" %> if you want them to match.
        </p>
      <% end %>
    </div>
  <% end %>
<% end %>
