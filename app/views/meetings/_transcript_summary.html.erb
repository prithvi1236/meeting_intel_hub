<%= turbo_frame_tag "transcript-summary" do %>
  <% transcript = local_assigns.fetch(:transcript) { meeting.transcript } %>
  <% project_for_links = local_assigns[:project] || meeting.project %>
  <% if transcript.blank? %>
    <div class="rounded-[10px] border border-dashed border-[var(--mi-border)] bg-[var(--mi-bg)]/40 px-4 py-3 text-sm text-[var(--mi-text)]/75">
      No transcript uploaded yet. Use <span class="font-medium text-[var(--mi-text)]">Upload meeting</span> on the project to add one.
    </div>
  <% elsif meeting.failed? && transcript.parsed_segments.blank? %>
    <div class="rounded-[10px] border border-[var(--mi-red)]/40 bg-[var(--mi-red)]/10 px-4 py-3 text-sm text-[var(--mi-red)]">
      <p class="font-medium">Transcript could not be processed</p>
      <% if meeting.processing_error.present? %>
        <p class="mt-1 text-xs opacity-90"><%= meeting.processing_error %></p>
      <% end %>
    </div>
  <% elsif transcript.parsed_segments.blank? %>
    <div class="rounded-[10px] border border-[var(--mi-border)] bg-[var(--mi-surface)] px-4 py-3">
      <p class="mb-2 text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Transcript summary</p>
      <div class="flex flex-wrap items-center gap-3 text-sm">
        <span class="truncate font-medium text-[var(--mi-text)]" title="<%= transcript.file_name %>"><%= transcript.file_name %></span>
        <span class="rounded-full border border-[var(--mi-border)] px-2 py-0.5 text-xs font-mono-mi text-[var(--mi-text)]/75">.<%= transcript.file_format %></span>
      </div>
      <p class="mt-3 flex items-center gap-2 text-sm text-[var(--mi-text)]/75">
        <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--mi-teal)]" aria-hidden="true"></span>
        Parsing transcript… speaker count and word total will appear here shortly.
      </p>
    </div>
  <% else %>
    <div class="rounded-[10px] border border-[var(--mi-border)] bg-[var(--mi-surface)] px-4 py-3">
      <p class="mb-3 text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Transcript summary</p>
      <dl class="grid gap-3 text-sm sm:grid-cols-2">
        <div>
          <dt class="text-xs font-medium text-[var(--mi-text)]/75">File</dt>
          <dd class="mt-0.5 truncate font-medium text-[var(--mi-text)]" title="<%= transcript.file_name %>"><%= transcript.file_name %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-[var(--mi-text)]/75">Format</dt>
          <dd class="mt-0.5 text-[var(--mi-text)]"><span class="rounded-full border border-[var(--mi-border)] px-2 py-0.5 text-xs font-mono-mi">.<%= transcript.file_format %></span></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-[var(--mi-text)]/75">Word count</dt>
          <dd class="mt-0.5 font-mono-mi text-[var(--mi-text)]"><%= number_with_delimiter(meeting.word_count.to_i) %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-[var(--mi-text)]/75">Speakers identified</dt>
          <dd class="mt-0.5 font-mono-mi text-[var(--mi-text)]"><%= transcript.total_speakers.to_i %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-xs font-medium text-[var(--mi-text)]/75">Detected from file</dt>
          <dd class="mt-0.5 text-[var(--mi-text)]">
            <% if transcript.detected_meeting_date.present? %>
              <%= transcript.detected_meeting_date.to_fs(:long) %>
            <% else %>
              <span class="text-[var(--mi-text)]/55">—</span>
            <% end %>
          </dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-xs font-medium text-[var(--mi-text)]/75">Meeting date (calendar)</dt>
          <dd class="mt-0.5 text-[var(--mi-text)]">
            <% if meeting.meeting_date.present? %>
              <%= meeting.meeting_date.to_fs(:long) %>
            <% else %>
              <span class="text-[var(--mi-text)]/70">Not set — <%= link_to "add in edit", edit_project_meeting_path(project_for_links, meeting), class: "text-[var(--mi-teal)] hover:underline", data: { turbo_frame: "meeting-detail" } %></span>
            <% end %>
          </dd>
        </div>
      </dl>
      <% if transcript.detected_meeting_date.present? && meeting.meeting_date.present? && transcript.detected_meeting_date != meeting.meeting_date %>
        <p class="mt-3 border-t border-[var(--mi-border)] pt-3 text-xs leading-relaxed text-[var(--mi-text)]/70">
          The date in the file differs from the meeting’s calendar date. You can <%= link_to "update the meeting", edit_project_meeting_path(project_for_links, meeting), class: "text-[var(--mi-teal)] hover:underline", data: { turbo_frame: "meeting-detail" } %> if you want them to match.
        </p>
      <% end %>
    </div>
  <% end %>
<% end %>
