<% modal = local_assigns.fetch(:modal, false) %>
<% edit_btn = "rounded-lg border border-[var(--mi-border)] bg-[var(--mi-surface)] px-2.5 py-1 text-[11px] font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text-secondary)] transition-colors hover:border-[var(--mi-teal)]/40 hover:text-[var(--mi-text)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--mi-teal)]/40" %>
<div class="flex flex-col gap-3">
  <% unless modal %>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Export CSV", export_items_api_v1_meeting_path(meeting, format: :csv), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-xs font-mono-mi" %>
      <%= link_to "Export PDF", export_items_api_v1_meeting_path(meeting, format: :pdf), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-xs font-mono-mi" %>
    </div>
  <% end %>

  <% if meeting.processing? %>
    <div class="space-y-2" aria-busy="true">
      <% 4.times do %>
        <div class="h-16 animate-pulse rounded-[12px] bg-[var(--mi-border)]/30"></div>
      <% end %>
    </div>
  <% else %>
    <% decisions = meeting.extracted_items.decisions.order(:position, :created_at) %>
    <% actions = meeting.extracted_items.action_items.order(:position, :created_at) %>
    <% if modal %>
      <div class="flex flex-col gap-6">
        <div data-controller="extracted-table-edit">
          <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
            <p class="text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Decisions</p>
            <% if decisions.any? %>
              <button
                type="button"
                class="<%= edit_btn %>"
                data-extracted-table-edit-target="toggleButton"
                data-action="click->extracted-table-edit#toggle"
                aria-pressed="false"
                aria-label="Toggle editing decisions"
              >
                Edit
              </button>
            <% end %>
          </div>
          <% if decisions.any? %>
            <div data-extracted-table-edit-target="view" class="overflow-x-auto">
              <table class="min-w-[640px] w-full border-collapse text-left text-sm">
                <%= render "extracted_items/modal_table_head_readonly" %>
                <tbody>
                  <% decisions.each do |item| %>
                    <%= render "extracted_items/modal_row_readonly", item: item, project: meeting.project, meeting: meeting %>
                  <% end %>
                </tbody>
              </table>
            </div>
            <div data-extracted-table-edit-target="edit" class="hidden overflow-x-auto">
              <table class="min-w-[640px] w-full border-collapse text-left text-sm">
                <%= render "extracted_items/modal_table_head" %>
                <tbody>
                  <% decisions.each do |item| %>
                    <%= render "extracted_items/modal_row", item: item, project: meeting.project, meeting: meeting %>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-sm text-[var(--mi-text)]/70">No decisions extracted.</p>
          <% end %>
        </div>

        <div data-controller="extracted-table-edit">
          <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
            <p class="text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Action items</p>
            <% if actions.any? %>
              <button
                type="button"
                class="<%= edit_btn %>"
                data-extracted-table-edit-target="toggleButton"
                data-action="click->extracted-table-edit#toggle"
                aria-pressed="false"
                aria-label="Toggle editing action items"
              >
                Edit
              </button>
            <% end %>
          </div>
          <% if actions.any? %>
            <div data-extracted-table-edit-target="view" class="overflow-x-auto">
              <table class="min-w-[640px] w-full border-collapse text-left text-sm">
                <%= render "extracted_items/modal_table_head_readonly" %>
                <tbody>
                  <% actions.each do |item| %>
                    <%= render "extracted_items/modal_row_readonly", item: item, project: meeting.project, meeting: meeting %>
                  <% end %>
                </tbody>
              </table>
            </div>
            <div data-extracted-table-edit-target="edit" class="hidden overflow-x-auto">
              <table class="min-w-[640px] w-full border-collapse text-left text-sm">
                <%= render "extracted_items/modal_table_head" %>
                <tbody>
                  <% actions.each do |item| %>
                    <%= render "extracted_items/modal_row", item: item, project: meeting.project, meeting: meeting %>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-sm text-[var(--mi-text)]/70">No action items extracted.</p>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="space-y-4">
        <div>
          <p class="mb-2 text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Decisions</p>
          <% if decisions.any? %>
            <div class="space-y-2">
              <% decisions.each do |item| %>
                <%= render "extracted_items/item", item: item, project: meeting.project, meeting: meeting %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-[var(--mi-text)]/70">No decisions extracted.</p>
          <% end %>
        </div>
        <div>
          <p class="mb-2 text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Action items</p>
          <% if actions.any? %>
            <div class="space-y-2">
              <% actions.each do |item| %>
                <%= render "extracted_items/item", item: item, project: meeting.project, meeting: meeting %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-[var(--mi-text)]/70">No action items extracted.</p>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
