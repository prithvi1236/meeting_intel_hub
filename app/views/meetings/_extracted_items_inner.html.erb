<% modal = local_assigns.fetch(:modal, false) %>
<div class="flex flex-col gap-3">
  <% unless modal %>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Export CSV", export_items_api_v1_meeting_path(meeting, format: :csv), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-xs font-mono-mi" %>
      <%= link_to "Export PDF", export_items_api_v1_meeting_path(meeting, format: :pdf), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-xs font-mono-mi" %>
    </div>
  <% end %>

  <% if meeting.processing? %>
    <div class="space-y-2" aria-busy="true">
      <% 4.times do %>
        <div class="h-16 animate-pulse rounded-[12px] bg-[var(--mi-border)]/30"></div>
      <% end %>
    </div>
  <% else %>
    <% decisions = meeting.extracted_items.decisions.order(:position, :created_at) %>
    <% actions = meeting.extracted_items.action_items.order(:position, :created_at) %>
    <% if modal %>
      <div data-controller="extracted-items-toggle" class="flex flex-col gap-3">
        <div
          role="tablist"
          aria-label="Extracted item type"
          class="inline-flex w-full max-w-md rounded-lg border border-[var(--mi-border)] bg-[var(--mi-bg)]/50 p-0.5"
        >
          <button
            type="button"
            role="tab"
            id="peek-tab-actions"
            aria-selected="true"
            aria-controls="peek-panel-actions"
            data-extracted-items-toggle-target="tabActions"
            data-action="click->extracted-items-toggle#selectActions"
            class="flex-1 rounded-md bg-[var(--mi-surface)] px-3 py-1.5 text-center text-xs font-mono-mi text-[var(--mi-text)] shadow-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--mi-teal)]/40"
          >
            Action items
          </button>
          <button
            type="button"
            role="tab"
            id="peek-tab-decisions"
            aria-selected="false"
            aria-controls="peek-panel-decisions"
            data-extracted-items-toggle-target="tabDecisions"
            data-action="click->extracted-items-toggle#selectDecisions"
            class="flex-1 rounded-md px-3 py-1.5 text-center text-xs font-mono-mi text-[var(--mi-text-secondary)] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--mi-teal)]/40"
          >
            Decisions
          </button>
        </div>
        <div
          id="peek-panel-actions"
          role="tabpanel"
          aria-labelledby="peek-tab-actions"
          data-extracted-items-toggle-target="panelActions"
        >
          <% if actions.any? %>
            <div class="space-y-2">
              <% actions.each do |item| %>
                <%= render "extracted_items/item", item: item, project: meeting.project, meeting: meeting %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-[var(--mi-text)]/70">No action items extracted.</p>
          <% end %>
        </div>
        <div
          id="peek-panel-decisions"
          role="tabpanel"
          aria-labelledby="peek-tab-decisions"
          data-extracted-items-toggle-target="panelDecisions"
          class="hidden"
        >
          <% if decisions.any? %>
            <div class="space-y-2">
              <% decisions.each do |item| %>
                <%= render "extracted_items/item", item: item, project: meeting.project, meeting: meeting %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-[var(--mi-text)]/70">No decisions extracted.</p>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="space-y-4">
        <div>
          <p class="mb-2 text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Decisions</p>
          <% if decisions.any? %>
            <div class="space-y-2">
              <% decisions.each do |item| %>
                <%= render "extracted_items/item", item: item, project: meeting.project, meeting: meeting %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-[var(--mi-text)]/70">No decisions extracted.</p>
          <% end %>
        </div>
        <div>
          <p class="mb-2 text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Action items</p>
          <% if actions.any? %>
            <div class="space-y-2">
              <% actions.each do |item| %>
                <%= render "extracted_items/item", item: item, project: meeting.project, meeting: meeting %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-[var(--mi-text)]/70">No action items extracted.</p>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
