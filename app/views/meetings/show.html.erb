<% content_for :title, @meeting.title %>
<% content_for :breadcrumb do %>
  <%= link_to "Projects", projects_path %> /
  <%= link_to @project.name, @project %> /
  <%= @meeting.title %>
<% end %>

<%= turbo_stream_from "meeting_#{@meeting.id}" %>

<div class="mb-4 flex flex-wrap items-center justify-between gap-2">
  <div>
    <h1 class="text-2xl font-semibold"><%= @meeting.title %></h1>
    <p class="text-xs font-mono-mi text-[var(--mi-text-secondary)]"><%= @meeting.status %> · <%= @meeting.meeting_date&.to_fs(:long) %></p>
    <% if @meeting.processing_error.present? %>
      <p class="mt-2 text-sm text-[var(--mi-red)]"><%= @meeting.processing_error %></p>
    <% end %>
  </div>
  <div class="flex flex-wrap items-center gap-2">
    <%= link_to "Cross-meeting chat", project_chat_sessions_path(@project), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-sm" %>
    <%= link_to "Edit", edit_project_meeting_path(@project, @meeting), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-sm" %>
    <%= button_to "Delete meeting",
          project_meeting_path(@project, @meeting),
          method: :delete,
          class: "rounded-[8px] border border-[var(--mi-red)] px-3 py-1.5 text-sm text-[var(--mi-red)]",
          form: { data: { turbo_confirm: "Delete this meeting and all extracted data?" } } %>
  </div>
</div>

<div
  class="mb-6 rounded-[12px] border border-[var(--mi-border)] bg-[var(--mi-surface)] p-4"
  data-controller="processing-status"
  data-processing-status-meeting-id-value="<%= @meeting.id %>"
>
  <p class="text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)] mb-3">Processing</p>
  <ul class="space-y-2 text-sm">
    <% %w[parsing embedding extract sentiment].each do |step| %>
      <li class="flex flex-col gap-1" data-step="<%= step %>" data-state="idle">
        <div class="flex items-center gap-2">
          <span data-role="icon" class="font-mono-mi w-4 text-center text-[var(--mi-text-secondary)]">·</span>
          <span><%= step.humanize %></span>
        </div>
        <% if step == "extract" %>
          <pre
            class="mt-1 hidden max-h-28 w-full overflow-x-auto overflow-y-auto whitespace-pre-wrap break-words rounded-[6px] border border-[var(--mi-border)] bg-[var(--mi-bg)] p-2 text-[10px] font-mono-mi leading-snug text-[var(--mi-text-secondary)]"
            data-role="extract-stream"
            aria-live="polite"
            aria-label="Extraction output preview"
          ></pre>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>

<div class="flex flex-col gap-6 lg:flex-row">
  <section class="w-full shrink-0 lg:w-[340px]" aria-label="Extracted items">
    <%= render "meetings/extracted_items_container", meeting: @meeting %>
  </section>

  <section class="min-w-0 flex-1" aria-label="Sentiment">
    <%= render "meetings/sentiment_dashboard", meeting: @meeting %>
  </section>
</div>

<div class="mt-8 space-y-4">
  <%= render "meetings/transcript_summary", meeting: @meeting, transcript: @transcript, project: @project %>
  <div class="rounded-[12px] border border-[var(--mi-border)] bg-[var(--mi-surface)] p-4">
    <h2 class="text-sm font-mono-mi uppercase text-[var(--mi-text-secondary)] mb-3">Transcript</h2>
    <%= render "meetings/transcript_upload", project: @project, meeting: @meeting %>
  </div>
</div>
