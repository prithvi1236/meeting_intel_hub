<% content_for :title, @meeting.title %>
<% content_for :breadcrumb do %>
  <%= link_to "Projects", projects_path %> /
  <%= link_to @project.name, @project %> /
  <%= @meeting.title %>
<% end %>

<%= turbo_stream_from "meeting_#{@meeting.id}" %>
<%= turbo_stream_from "chat_session_#{@chat_session.id}" %>

<div class="mb-4 flex flex-wrap items-center justify-between gap-2">
  <div>
    <h1 class="text-2xl font-semibold"><%= @meeting.title %></h1>
    <p class="text-xs font-mono-mi text-[var(--mi-text-secondary)]"><%= @meeting.status %> · <%= @meeting.meeting_date&.to_fs(:long) %></p>
    <% if @meeting.processing_error.present? %>
      <p class="mt-2 text-sm text-[var(--mi-red)]"><%= @meeting.processing_error %></p>
    <% end %>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_project_meeting_path(@project, @meeting), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-sm" %>
    <%= button_to "Delete meeting",
          project_meeting_path(@project, @meeting),
          method: :delete,
          class: "rounded-[8px] border border-[var(--mi-red)] px-3 py-1.5 text-sm text-[var(--mi-red)]",
          form: { data: { turbo_confirm: "Delete this meeting and all extracted data?" } } %>
  </div>
</div>

<div
  class="mb-6 rounded-[12px] border border-[var(--mi-border)] bg-[var(--mi-surface)] p-4"
  data-controller="processing-status"
  data-processing-status-meeting-id-value="<%= @meeting.id %>"
>
  <p class="text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)] mb-3">Processing</p>
  <ul class="space-y-2 text-sm">
    <% %w[parsing embedding extract sentiment].each do |step| %>
      <li class="flex flex-col gap-1" data-step="<%= step %>" data-state="idle">
        <div class="flex items-center gap-2">
          <span data-role="icon" class="font-mono-mi w-4 text-center text-[var(--mi-text-secondary)]">·</span>
          <span><%= step.humanize %></span>
        </div>
        <% if step == "extract" %>
          <pre
            class="mt-1 hidden max-h-28 w-full overflow-x-auto overflow-y-auto whitespace-pre-wrap break-words rounded-[6px] border border-[var(--mi-border)] bg-[var(--mi-bg)] p-2 text-[10px] font-mono-mi leading-snug text-[var(--mi-text-secondary)]"
            data-role="extract-stream"
            aria-live="polite"
            aria-label="Extraction output preview"
          ></pre>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>

<div class="flex flex-col gap-6 xl:flex-row">
  <section class="order-2 w-full shrink-0 xl:order-1 xl:w-[320px]" aria-label="Extracted items">
    <%= render "meetings/extracted_items_container", meeting: @meeting %>
  </section>

  <section class="order-1 min-w-0 flex-1 xl:order-2" aria-label="Chat">
    <div
      class="flex h-[min(70vh,640px)] flex-col rounded-[12px] border border-[var(--mi-border)] bg-[var(--mi-surface)]"
      data-controller="chat"
      data-chat-session-id-value="<%= @chat_session.id %>"
    >
      <div class="border-b border-[var(--mi-border)] px-4 py-2 text-xs font-mono-mi text-[var(--mi-text-secondary)]">
        Ask questions about this meeting
      </div>
      <div id="chat-messages" data-chat-target="messages" class="flex-1 space-y-3 overflow-y-auto p-4">
        <% if @messages.empty? %>
          <p class="text-sm text-[var(--mi-text-secondary)]">Try:</p>
          <ul class="list-disc pl-5 text-sm text-[var(--mi-teal)] space-y-1">
            <li><button type="button" class="text-left hover:underline" data-action="click->chat#fillSuggested">What decisions were made?</button></li>
            <li><button type="button" class="text-left hover:underline" data-action="click->chat#fillSuggested">Who has the most action items?</button></li>
            <li><button type="button" class="text-left hover:underline" data-action="click->chat#fillSuggested">What were the main concerns raised?</button></li>
          </ul>
        <% end %>
        <% @messages.each do |message| %>
          <%= render "chat_messages/message", message: message %>
        <% end %>
      </div>
      <div data-chat-target="typing" class="hidden px-4 pb-2 text-xs font-mono-mi text-[var(--mi-text-secondary)]" aria-live="polite">Assistant is typing…</div>
      <%= form_with url: project_meeting_chat_session_chat_messages_path(@project, @meeting, @chat_session),
            data: {
              action: "turbo:submit-start->chat#prepareSubmit turbo:submit-end->chat#turboAfterSubmit"
            } do |f| %>
        <div class="flex gap-2 border-t border-[var(--mi-border)] p-3">
          <%= text_area_tag "chat_message[content]", nil,
                rows: 2,
                data: { chat_target: "input", action: "keydown->chat#handleKeydown" },
                class: "min-w-0 flex-1 resize-none rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)] px-3 py-2 text-sm",
                placeholder: "Message…",
                "aria-label": "Chat message" %>
          <%= f.submit "Send", class: "self-end rounded-[8px] bg-[var(--mi-teal)] px-4 py-2 text-sm font-medium text-[#0f0f0f] cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="order-3 w-full shrink-0 xl:w-[320px]" aria-label="Sentiment">
    <%= render "meetings/sentiment_dashboard", meeting: @meeting %>
  </section>
</div>

<div class="mt-8 rounded-[12px] border border-[var(--mi-border)] bg-[var(--mi-surface)] p-4">
  <h2 class="text-sm font-mono-mi uppercase text-[var(--mi-text-secondary)] mb-3">Transcript</h2>
  <%= render "meetings/transcript_upload", project: @project, meeting: @meeting %>
</div>
