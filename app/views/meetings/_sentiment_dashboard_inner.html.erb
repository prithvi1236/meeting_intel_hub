<% sentiment = (meeting.sentiment_data || {}).with_indifferent_access %>
<div class="flex flex-col gap-4">
  <div>
    <p class="text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Overall sentiment</p>
    <% score = meeting.overall_sentiment_score %>
    <p class="text-4xl font-semibold <%= sentiment_color(score) %>">
      <%= score ? number_with_precision(score, precision: 2) : "—" %>
    </p>
  </div>

  <% timeline = Array(sentiment[:timeline]) %>
  <%= tag.div(
        data: {
          controller: "sentiment-timeline",
          sentiment_timeline_segments_value: timeline
        }
      ) do %>
    <p class="mb-2 text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Timeline</p>
    <canvas
      data-sentiment-timeline-target="canvas"
      data-action="click->sentiment-timeline#click"
      class="h-10 w-full min-w-[120px] cursor-pointer rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)]"
      aria-label="Sentiment timeline; click a segment to read transcript"
    ></canvas>
    <% if timeline.any? %>
      <p
        data-sentiment-timeline-target="snippetMeta"
        class="mt-2 text-xs text-[var(--mi-text-secondary)]"
      >
        Click a colored section to view the transcript for that period.
      </p>
      <pre
        data-sentiment-timeline-target="snippet"
        class="mt-2 hidden max-h-48 overflow-y-auto whitespace-pre-wrap break-words rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)] p-3 font-mono-mi text-[13px] leading-relaxed text-[var(--mi-text)] [scrollbar-width:thin]"
      ></pre>
      <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1.5 text-[10px] font-mono-mi uppercase tracking-wide text-[var(--mi-text-secondary)]" role="group" aria-label="Timeline color key">
        <span class="inline-flex items-center gap-1.5">
          <span class="h-2.5 w-4 shrink-0 rounded-sm bg-[var(--mi-green)]"></span>
          Positive / consensus
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-2.5 w-4 shrink-0 rounded-sm bg-[var(--mi-teal)]"></span>
          Discussion
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-2.5 w-4 shrink-0 rounded-sm bg-[var(--mi-amber)]"></span>
          Tension
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-2.5 w-4 shrink-0 rounded-sm bg-[var(--mi-red)]"></span>
          Negative / conflict
        </span>
      </div>
    <% end %>
  <% end %>

  <% speakers = Array(sentiment[:per_speaker]).filter_map { |row| row.is_a?(Hash) ? row.with_indifferent_access : nil } %>
  <div>
    <p class="mb-2 text-xs font-mono-mi font-medium uppercase tracking-wide text-[var(--mi-text)]/85">Speakers</p>
    <ul class="space-y-3">
      <% speakers.each do |s| %>
        <li class="flex items-center gap-3 rounded-[8px] border border-[var(--mi-border)] px-3 py-2">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--mi-border)] text-xs font-mono-mi">
            <%= s[:name].to_s.first(2).upcase %>
          </div>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-medium"><%= s[:name].presence || "Speaker" %></p>
            <p class="text-xs text-[var(--mi-text)]/70"><%= s[:dominant_emotion].presence || "—" %></p>
          </div>
          <span class="text-sm font-mono-mi <%= sentiment_color(s[:average_score]) %>">
            <%= number_with_precision(s[:average_score].to_f, precision: 2) %>
          </span>
        </li>
      <% end %>
    </ul>
    <% if speakers.empty? && !meeting.processing? %>
      <p class="text-sm text-[var(--mi-text)]/70">No speaker sentiment yet.</p>
    <% end %>
  </div>
</div>
