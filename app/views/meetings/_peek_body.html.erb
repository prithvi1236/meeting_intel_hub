<%# locals: project, meeting %>
<% transcript = meeting.transcript %>
<% btn_export = "inline-flex items-center justify-center rounded-lg border border-[var(--mi-border)] bg-[var(--mi-surface)] px-3 py-1.5 text-xs font-mono-mi text-[var(--mi-text)] transition-colors hover:border-[var(--mi-teal)]/40 hover:bg-[var(--mi-teal)]/[0.06] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--mi-teal)]/40 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--mi-surface)]" %>
<% icon_btn = "inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[var(--mi-border)] bg-[var(--mi-surface)] text-[var(--mi-text)] transition-colors hover:border-[var(--mi-teal)]/40 hover:bg-[var(--mi-teal)]/[0.06] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--mi-teal)]/40 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--mi-surface)]" %>
<% icon_btn_edit = "inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[var(--mi-teal)]/45 bg-[var(--mi-teal)]/[0.1] text-[var(--mi-teal)] transition-colors hover:border-[var(--mi-teal)]/70 hover:bg-[var(--mi-teal)]/[0.18] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--mi-teal)]/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--mi-surface)]" %>
<% icon_btn_danger = "inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[var(--mi-red)]/45 bg-[var(--mi-red)]/[0.06] text-[var(--mi-red)] transition-colors hover:bg-[var(--mi-red)]/[0.14] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--mi-red)]/35 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--mi-surface)]" %>
<% status_pill =
     case meeting.status
     when "completed"
       "border-[var(--mi-green)]/30 bg-[var(--mi-green)]/[0.12] text-[var(--mi-green)]"
     when "failed"
       "border-[var(--mi-red)]/35 bg-[var(--mi-red)]/[0.1] text-[var(--mi-red)]"
     when "processing", "pending"
       "border-[var(--mi-teal)]/30 bg-[var(--mi-teal)]/[0.1] text-[var(--mi-teal)]"
     else
       "border-[var(--mi-border)] bg-[var(--mi-bg)]/50 text-[var(--mi-text-secondary)]"
     end %>
<% panel = "rounded-xl border border-[var(--mi-border)] bg-[var(--mi-surface)] shadow-sm" %>
<% panel_header = "border-b border-[var(--mi-border)] px-3 py-2.5 text-[11px] font-mono-mi font-medium uppercase tracking-[0.14em] text-[var(--mi-text)]/85" %>
<%= turbo_stream_from "meeting_#{meeting.id}" %>

<div class="flex max-h-[min(85vh,720px)] min-h-[320px] flex-col gap-5 overflow-hidden">
  <header class="rounded-xl border border-[var(--mi-border)] bg-gradient-to-b from-[var(--mi-bg)]/80 to-[var(--mi-surface)] p-4 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0 flex-1">
        <p class="text-[11px] font-mono-mi uppercase tracking-[0.12em] text-[var(--mi-text)]/70">Meeting</p>
        <h2 class="mt-1 truncate text-xl font-semibold leading-tight tracking-tight text-[var(--mi-text)]"><%= meeting.title %></h2>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <span class="rounded-md border px-2 py-0.5 text-[10px] font-mono-mi uppercase tracking-wider <%= status_pill %>">
            <%= meeting.status %>
          </span>
          <% if meeting.meeting_date.present? %>
            <span class="text-xs text-[var(--mi-text)]/75"><%= meeting.meeting_date.to_fs(:long) %></span>
          <% end %>
        </div>
        <% if meeting.processing_error.present? %>
          <p class="mt-3 rounded-lg border border-[var(--mi-red)]/35 bg-[var(--mi-red)]/[0.08] px-3 py-2 text-sm leading-snug text-[var(--mi-red)]">
            <%= meeting.processing_error %>
          </p>
        <% end %>
      </div>
      <nav class="flex flex-wrap gap-2 sm:justify-end" aria-label="Meeting actions">
        <%= link_to "Export CSV",
              export_items_api_v1_meeting_path(meeting, format: :csv),
              class: btn_export,
              data: { turbo: false } %>
        <%= link_to "Export PDF",
              export_items_api_v1_meeting_path(meeting, format: :pdf),
              class: btn_export,
              data: { turbo: false } %>
        <%= link_to edit_project_meeting_path(project, meeting),
              class: icon_btn_edit,
              aria: { label: "Edit meeting" },
              title: "Edit meeting",
              data: { turbo_frame: "meeting-detail" } do %>
          <%= render "shared/mi_icon", name: :pencil, class: "h-5 w-5" %>
        <% end %>
        <%= button_to project_meeting_path(project, meeting),
              method: :delete,
              class: icon_btn_danger,
              title: "Delete meeting",
              form: {
                class: "inline",
                data: { turbo_confirm: "Delete this meeting and all extracted data?", turbo_frame: "_top" }
              },
              aria: { label: "Delete meeting" } do %>
          <%= render "shared/mi_icon", name: :trash, class: "h-5 w-5" %>
        <% end %>
      </nav>
    </div>
  </header>

  <div class="grid min-h-0 flex-1 gap-4 lg:grid-cols-2 lg:gap-5">
    <section class="flex min-h-0 flex-col gap-4 lg:h-full">
      <div class="flex min-h-0 flex-1 flex-col <%= panel %> overflow-hidden bg-[var(--mi-bg)]/35" aria-label="Transcript text">
        <p class="<%= panel_header %> bg-[var(--mi-surface)]/60">Transcript</p>
        <div class="min-h-0 flex-1 overflow-y-auto p-3.5 [scrollbar-width:thin] [scrollbar-color:var(--mi-border)_transparent]">
          <% if transcript&.raw_content.present? %>
            <pre class="whitespace-pre-wrap break-words font-mono-mi text-[13px] leading-[1.65] text-[var(--mi-text)]"><%= transcript.raw_content %></pre>
          <% elsif meeting.processing? %>
            <p class="flex items-center gap-2.5 text-sm text-[var(--mi-text-secondary)]">
              <span class="relative flex h-2 w-2 shrink-0" aria-hidden="true">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--mi-teal)] opacity-35 motion-reduce:hidden"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--mi-teal)]"></span>
              </span>
              Processing transcript…
            </p>
          <% else %>
            <p class="text-sm leading-relaxed text-[var(--mi-text-secondary)]">No transcript text yet.</p>
          <% end %>
        </div>
      </div>

      <div class="<%= panel %> p-3.5">
        <%= render "meetings/transcript_summary", meeting: meeting, transcript: transcript, project: project %>
      </div>
    </section>

    <div class="flex min-h-0 flex-col gap-4 overflow-hidden lg:h-full lg:gap-5">
      <section class="<%= panel %> flex min-h-0 max-h-[min(50vh,400px)] shrink-0 flex-col overflow-hidden p-0" aria-label="Decisions and actions">
        <p class="<%= panel_header %> shrink-0 bg-[var(--mi-surface)]/60">Actions &amp; decisions</p>
        <div class="min-h-0 flex-1 overflow-y-auto p-3.5 [scrollbar-width:thin] [scrollbar-color:var(--mi-border)_transparent]">
          <%= render "meetings/extracted_items_inner", meeting: meeting, modal: true %>
        </div>
      </section>
      <section class="<%= panel %> flex min-h-0 flex-1 flex-col overflow-hidden p-0" aria-label="Sentiment">
        <p class="<%= panel_header %> shrink-0 bg-[var(--mi-surface)]/60">Sentiment</p>
        <div class="min-h-0 flex-1 overflow-y-auto p-3.5 [scrollbar-width:thin] [scrollbar-color:var(--mi-border)_transparent]">
          <%= render "meetings/sentiment_dashboard", meeting: meeting %>
        </div>
      </section>
    </div>
  </div>
</div>
