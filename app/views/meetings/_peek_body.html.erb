<%# locals: project, meeting %>
<% transcript = meeting.transcript %>
<%= turbo_stream_from "meeting_#{meeting.id}" %>

<div class="flex min-h-[calc(100vh-12rem)] flex-col gap-5 overflow-hidden">
  <header class="rounded-xl border border-[var(--mi-border)] bg-gradient-to-b from-[var(--mi-bg)]/80 to-[var(--mi-surface)] p-4 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0 flex-1">
        <p class="text-[11px] font-mono-mi uppercase tracking-[0.12em] text-[var(--mi-text)]/70">Meeting</p>
        <h2 class="mt-1 truncate text-xl font-semibold leading-tight tracking-tight text-[var(--mi-text)]"><%= meeting.title %></h2>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <span class="rounded-md border px-2 py-0.5 text-[10px] font-mono-mi uppercase tracking-wider <%= mi_meeting_status_pill_class(meeting.status) %>">
            <%= meeting.status %>
          </span>
          <% if meeting.meeting_date.present? %>
            <span class="text-xs text-[var(--mi-text)]/75"><%= meeting.meeting_date.to_fs(:long) %></span>
          <% end %>
        </div>
        <% if meeting.processing_error.present? %>
          <p class="mt-3 rounded-lg border border-[var(--mi-red)]/35 bg-[var(--mi-red)]/[0.08] px-3 py-2 text-sm leading-snug text-[var(--mi-red)]">
            <%= meeting.processing_error %>
          </p>
        <% end %>
      </div>
      <nav class="flex flex-wrap gap-2 sm:justify-end" aria-label="Meeting actions">
        <%= link_to edit_project_meeting_path(project, meeting),
              class: mi_icon_btn_edit_class,
              aria: { label: "Edit meeting" },
              title: "Edit meeting" do %>
          <%= render "shared/mi_icon", name: :pencil, class: "h-5 w-5" %>
        <% end %>
        <%= button_to project_meeting_path(project, meeting),
              method: :delete,
              class: mi_icon_btn_danger_class,
              title: "Delete meeting",
              form: {
                class: "inline",
                data: { turbo_confirm: "Delete this meeting and all extracted data?", turbo_frame: "_top" }
              },
              aria: { label: "Delete meeting" } do %>
          <%= render "shared/mi_icon", name: :trash, class: "h-5 w-5" %>
        <% end %>
      </nav>
    </div>
  </header>

  <div class="grid min-h-0 flex-1 gap-4 lg:grid-cols-3 lg:gap-5">
    <section class="flex min-h-0 flex-col gap-4 lg:h-full">
      <div class="flex min-h-0 flex-1 flex-col <%= mi_panel_class %> overflow-hidden bg-[var(--mi-bg)]/35" aria-label="Transcript text">
        <p class="<%= mi_panel_header_class %> bg-[var(--mi-surface)]/60">Transcript</p>
        <div class="<%= mi_peek_scroll_body_class %>">
          <% segs = transcript&.parsed_segments_normalized %>
          <% if segs.present? %>
            <div class="flex flex-col gap-4 text-left font-mono-mi text-[13px] leading-[1.65] text-[var(--mi-text)]">
              <% segs.each do |seg| %>
                <% body = seg["text"].to_s.lstrip %>
                <div class="flex min-w-0 flex-col gap-0.5 sm:flex-row sm:items-start sm:gap-2">
                  <span class="shrink-0 font-semibold text-[var(--mi-text)]"><%= seg["speaker"].to_s.strip %>:</span>
                  <span class="min-w-0 flex-1 whitespace-pre-wrap break-words"><%= body %></span>
                </div>
              <% end %>
            </div>
          <% elsif transcript&.raw_content.present? %>
            <pre class="w-full whitespace-pre-wrap break-words text-left font-mono-mi text-[13px] leading-[1.65] text-[var(--mi-text)]"><%= transcript.raw_content.to_s.lines.map(&:lstrip).join %></pre>
          <% elsif meeting.processing? %>
            <p class="flex items-center gap-2.5 text-sm text-[var(--mi-text-secondary)]">
              <span class="relative flex h-2 w-2 shrink-0" aria-hidden="true">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--mi-teal)] opacity-35 motion-reduce:hidden"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--mi-teal)]"></span>
              </span>
              Processing transcript…
            </p>
          <% else %>
            <p class="text-sm leading-relaxed text-[var(--mi-text-secondary)]">No transcript text yet.</p>
          <% end %>
        </div>
      </div>

      <section class="<%= mi_panel_class %> flex min-h-0 flex-1 flex-col overflow-hidden p-0" aria-label="Sentiment">
        <p class="<%= mi_panel_header_class %> shrink-0 bg-[var(--mi-surface)]/60">Sentiment</p>
        <div class="<%= mi_peek_scroll_body_class %>">
          <%= render "meetings/sentiment_dashboard", meeting: meeting %>
        </div>
      </section>
    </section>

    <section class="flex min-h-0 flex-1 flex-col overflow-hidden lg:h-full" aria-label="Meeting chat">
      <div class="<%= mi_panel_class %> flex min-h-0 flex-1 flex-col overflow-hidden p-0">
        <%= render "meetings/meeting_chat",
              project: project,
              meeting: meeting,
              chat_session: @chat_session,
              messages: @chat_messages %>
      </div>
    </section>

    <section class="flex min-h-0 flex-1 flex-col overflow-hidden lg:h-full" aria-label="Extracted items">
      <div class="<%= mi_panel_class %> flex min-h-0 flex-1 flex-col overflow-hidden p-0">
        <div class="<%= mi_peek_extracted_toolbar_class %>">
          <p class="<%= mi_panel_heading_muted_class %>">
            Extracted items
          </p>
          <nav class="flex flex-wrap items-center gap-2" aria-label="Export extracted items">
            <%= link_to "Export CSV",
                  export_items_api_v1_meeting_path(meeting, format: :csv),
                  class: mi_btn_export_class,
                  data: { turbo: false } %>
            <%= link_to "Export PDF",
                  export_items_api_v1_meeting_path(meeting, format: :pdf),
                  class: mi_btn_export_class,
                  data: { turbo: false } %>
          </nav>
        </div>
        <div class="<%= mi_peek_scroll_body_class %>">
          <%= render "meetings/extracted_items_inner", meeting: meeting, modal: true %>
        </div>
      </div>
    </section>
  </div>
</div>
