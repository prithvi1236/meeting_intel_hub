<%= form_with model: project, class: "space-y-4 max-w-xl" do |f| %>
  <% if project.errors.any? %>
    <div class="rounded-[8px] border border-[var(--mi-red)]/40 bg-[var(--mi-red)]/10 p-3 text-sm">
      <%= project.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div>
    <%= f.label :name, class: "block text-sm text-[var(--mi-text-secondary)]" %>
    <%= f.text_field :name, required: true, class: "mt-1 w-full rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)] px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :description, class: "block text-sm text-[var(--mi-text-secondary)]" %>
    <%= f.text_area :description, rows: 4, class: "mt-1 w-full rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)] px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :slug, "Slug (optional)", class: "block text-sm text-[var(--mi-text-secondary)]" %>
    <%= f.text_field :slug, class: "mt-1 w-full rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)] px-3 py-2 text-sm font-mono-mi text-xs" %>
  </div>
  <%= f.submit class: "rounded-[8px] bg-[var(--mi-teal)] px-4 py-2 text-sm font-medium text-[#0f0f0f] cursor-pointer" %>
<% end %>
