<%# locals: project, grouped, group, group_sort %>
<% processing_meetings = grouped.flat_map { |g| g[:meetings] }.select(&:processing?).uniq %>
<% processing_meetings.each do |m| %>
  <%= turbo_stream_from "meeting_#{m.id}" %>
<% end %>
<div id="project-meetings-groups" class="space-y-8">
  <% if grouped.empty? %>
    <%= render "shared/empty_state",
        title: "No meetings in this project",
        body: "Upload transcripts to generate insights, action items, and sentiment.",
        cta_path: project_path(project, upload: 1),
        cta_label: "Upload meeting" %>
  <% else %>
    <% grouped.each do |g| %>
      <section class="min-w-0">
        <h2 class="mb-3 text-xs font-mono-mi font-medium uppercase tracking-[0.12em] text-[var(--mi-text-secondary)]">
          <%= g[:label] %>
        </h2>
        <div
          class="flex gap-4 overflow-x-auto overscroll-x-contain pb-3 pt-0.5 snap-x snap-mandatory [-webkit-overflow-scrolling:touch] [scrollbar-color:var(--mi-border)_transparent] [scrollbar-width:thin] [&::-webkit-scrollbar]:h-1.5 [&::-webkit-scrollbar-track]:bg-transparent [&::-webkit-scrollbar-thumb]:rounded-full [&::-webkit-scrollbar-thumb]:bg-[var(--mi-border)] hover:[&::-webkit-scrollbar-thumb]:bg-[var(--mi-text-secondary)]/40"
        >
          <% g[:meetings].each do |m| %>
            <%= render "projects/meeting_card", project: project, meeting: m %>
          <% end %>
        </div>
      </section>
    <% end %>
  <% end %>
</div>
