<dialog
  data-meeting-upload-modal-target="dialog"
  class="fixed left-1/2 top-1/2 z-50 w-[min(100vw-2rem,640px)] max-h-[min(100vh-2rem,90vh)] -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-[12px] border border-[var(--mi-border)] bg-[var(--mi-surface)] p-0 shadow-xl backdrop:bg-black/60"
  aria-labelledby="upload-meeting-modal-title"
>
  <div class="flex max-h-[min(100vh-2rem,90vh)] flex-col">
    <div class="flex items-center justify-between border-b border-[var(--mi-border)] px-4 py-3">
      <h2 id="upload-meeting-modal-title" class="text-lg font-semibold">Upload meetings</h2>
      <button
        type="button"
        class="rounded-[8px] border border-[var(--mi-border)] px-3 py-1.5 text-sm"
        data-action="click->meeting-upload-modal#closeModal"
      >
        Close
      </button>
    </div>

    <div class="min-h-0 flex-1 space-y-4 overflow-y-auto p-4">
      <%= render "projects/meeting_import_errors", message: nil %>

      <div
        data-meeting-upload-modal-target="clientError"
        class="hidden rounded-[8px] border border-[var(--mi-red)]/40 bg-[var(--mi-red)]/10 px-3 py-2 text-sm text-[var(--mi-red)]"
        role="alert"
      ></div>

      <p class="text-xs text-[var(--mi-text-secondary)]">
        Drop or browse <span class="font-mono-mi">.txt</span> or <span class="font-mono-mi">.vtt</span> files. Review each row, then save to this project.
      </p>

      <div
        data-meeting-upload-modal-target="dropZone"
        data-action="
          dragover->meeting-upload-modal#highlight
          dragleave->meeting-upload-modal#unhighlight
          drop->meeting-upload-modal#handleDrop
          click->meeting-upload-modal#browse
        "
        class="flex min-h-[140px] cursor-pointer flex-col items-center justify-center rounded-[12px] border-2 border-dashed border-[var(--mi-border)] bg-[var(--mi-bg)]/40 px-4 py-6 text-center transition-colors"
        role="button"
        tabindex="0"
        aria-label="Drop transcript files or click to browse"
      >
        <p class="text-sm text-[var(--mi-text-secondary)]">Drag &amp; drop files here, or click to browse</p>
        <input
          type="file"
          multiple
          accept=".txt,.vtt,text/plain"
          class="hidden"
          data-meeting-upload-modal-target="fileInput"
          data-action="change->meeting-upload-modal#handleFileSelect"
        />
      </div>

      <form data-action="submit->meeting-upload-modal#save">
        <div data-meeting-upload-modal-target="rows" class="space-y-3"></div>
        <div class="mt-4 flex justify-end gap-2 border-t border-[var(--mi-border)] pt-4">
          <button
            type="button"
            class="rounded-[8px] border border-[var(--mi-border)] px-4 py-2 text-sm"
            data-action="click->meeting-upload-modal#closeModal"
          >
            Cancel
          </button>
          <button
            type="submit"
            data-meeting-upload-modal-target="saveButton"
            class="rounded-[8px] bg-[var(--mi-teal)] px-4 py-2 text-sm font-medium text-[#0f0f0f] disabled:cursor-not-allowed disabled:opacity-50"
            disabled
          >
            Save to project
          </button>
        </div>
      </form>
    </div>
  </div>
</dialog>
