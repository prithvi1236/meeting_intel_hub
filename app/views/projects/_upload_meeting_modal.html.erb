<dialog
  data-meeting-upload-modal-target="dialog"
  class="fixed left-1/2 top-1/2 z-50 w-[min(100vw-2rem,640px)] max-h-[min(100vh-2rem,90vh)] -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-xl border border-zinc-700 bg-zinc-900 p-0 shadow-2xl backdrop:bg-black/70 text-zinc-300"
  aria-labelledby="upload-meeting-modal-title"
>
  <form data-action="submit->meeting-upload-modal#save" class="flex max-h-[min(100vh-2rem,90vh)] flex-col">
    
    <div class="flex items-center justify-between border-b border-zinc-800 px-6 py-4">
      <h2 id="upload-meeting-modal-title" class="text-lg font-semibold text-white">Upload meetings</h2>
      <button
        type="button"
        class="rounded-full p-1.5 text-zinc-400 transition-colors hover:bg-zinc-800 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500"
        data-action="click->meeting-upload-modal#closeModal"
        aria-label="Close modal"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="min-h-0 flex-1 space-y-5 overflow-y-auto px-6 py-5">
      <%= render "projects/meeting_import_errors", message: nil %>

      <div
        data-meeting-upload-modal-target="clientError"
        class="hidden rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-400"
        role="alert"
      ></div>

      <div
        data-meeting-upload-modal-target="dropZone"
        data-action="
          dragover->meeting-upload-modal#highlight
          dragleave->meeting-upload-modal#unhighlight
          drop->meeting-upload-modal#handleDrop
          click->meeting-upload-modal#browse
        "
        class="group flex min-h-[160px] cursor-pointer flex-col items-center justify-center gap-3 rounded-xl border-2 border-dashed border-zinc-700 bg-zinc-800/30 px-6 py-8 text-center transition-all hover:border-teal-500 hover:bg-zinc-800/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500"
        role="button"
        tabindex="0"
        aria-label="Drop transcript files or click to browse"
      >
        <div class="rounded-full border border-zinc-700 bg-zinc-800 p-3 shadow-sm transition-transform group-hover:scale-105">
          <svg class="h-6 w-6 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-zinc-100">Click to browse or drag and drop</p>
          <p class="mt-1 text-xs text-zinc-400">
            Supported formats: 
            <span class="font-mono-mi rounded bg-zinc-800 px-1.5 py-0.5 text-zinc-300">.txt</span> or 
            <span class="font-mono-mi rounded bg-zinc-800 px-1.5 py-0.5 text-zinc-300">.vtt</span>
          </p>
        </div>
        <input
          type="file"
          multiple
          accept=".txt,.vtt,text/plain"
          class="hidden"
          data-meeting-upload-modal-target="fileInput"
          data-action="change->meeting-upload-modal#handleFileSelect"
        />
      </div>

      <div data-meeting-upload-modal-target="rows" class="space-y-3 empty:hidden text-zinc-200"></div>
    </div>

    <div class="flex shrink-0 justify-end gap-3 border-t border-zinc-800 bg-zinc-900/50 px-6 py-4">
      <button
        type="button"
        class="rounded-lg border border-zinc-700 px-4 py-2 text-sm font-medium text-zinc-300 transition-colors hover:bg-zinc-800 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500"
        data-action="click->meeting-upload-modal#closeModal"
      >
        Cancel
      </button>
      <button
        type="submit"
        data-meeting-upload-modal-target="saveButton"
        class="rounded-lg bg-[#00d1b2] px-4 py-2 text-sm font-medium text-zinc-900 transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900 focus-visible:ring-[#00d1b2] disabled:cursor-not-allowed disabled:opacity-50"
        disabled
      >
        Save to project
      </button>
    </div>
  </form>
</dialog>
