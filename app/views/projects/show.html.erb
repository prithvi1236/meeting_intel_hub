<% content_for :title, @project.name %>
<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path, class: "hover:underline" %> /
  <%= link_to "Projects", projects_path, class: "hover:underline" %> /
  <%= @project.name %>
<% end %>

<div
  class="space-y-6"
  data-controller="meeting-upload-modal"
  data-meeting-upload-modal-preview-url-value="<%= project_transcript_previews_path(@project) %>"
  data-meeting-upload-modal-import-url-value="<%= project_meeting_imports_path(@project) %>"
  data-meeting-upload-modal-group-value="<%= @group %>"
  data-meeting-upload-modal-group-sort-value="<%= @group_sort %>"
  data-meeting-upload-modal-open-value="<%= @open_upload_modal %>"
>
  <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold"><%= @project.name %></h1>
      <p class="text-sm text-[var(--mi-text-secondary)]"><%= @project.description %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit", edit_project_path(@project), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-2 text-sm" %>
      <%= link_to "Cross-meeting chat", project_chat_sessions_path(@project), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-2 text-sm" %>
      <button
        type="button"
        class="rounded-[8px] bg-[var(--mi-teal)] px-4 py-2 text-sm font-medium text-[#0f0f0f]"
        data-action="click->meeting-upload-modal#openModal"
      >
        Upload meeting
      </button>
      <%= button_to "Delete project",
            project_path(@project),
            method: :delete,
            class: "rounded-[8px] border border-[var(--mi-red)] px-3 py-2 text-sm text-[var(--mi-red)]",
            form: { data: { turbo_confirm: "Delete this project and all its meetings?", turbo_frame: "_top" } } %>
    </div>
  </div>

  <%= form_with url: project_path(@project), method: :get, class: "flex flex-wrap items-end gap-3" do %>
    <div>
      <label class="block text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)]">Group by</label>
      <%= select_tag :group,
            options_for_select(
              [
                [ "Meeting name", "title" ],
                [ "Day", "day" ],
                [ "Week", "week" ],
                [ "Month", "month" ]
              ],
              @group
            ),
            class: "mt-1 rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-surface)] px-3 py-2 text-sm",
            onchange: "this.form.requestSubmit()" %>
    </div>
    <div>
      <label class="block text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)]">Sort groups</label>
      <%= select_tag :group_sort,
            options_for_select(
              [
                [ "Latest meeting first", "latest" ],
                [ "Name / period (A–Z)", "name" ]
              ],
              @group_sort
            ),
            class: "mt-1 rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-surface)] px-3 py-2 text-sm",
            onchange: "this.form.requestSubmit()" %>
    </div>
  <% end %>

  <%= render "projects/meeting_groups",
      project: @project,
      grouped: @grouped,
      group: @group,
      group_sort: @group_sort %>

  <%= render "projects/upload_meeting_modal" %>
</div>
