<% content_for :title, @project.name %>
<% content_for :breadcrumb do %>
  <%= link_to "Projects", projects_path, class: "hover:underline" %> / <%= @project.name %>
<% end %>

<div
  class="space-y-6"
  data-controller="meeting-detail meeting-upload-modal"
  data-meeting-upload-modal-preview-url-value="<%= project_transcript_previews_path(@project) %>"
  data-meeting-upload-modal-import-url-value="<%= project_meeting_imports_path(@project) %>"
  data-meeting-upload-modal-group-value="<%= @group %>"
  data-meeting-upload-modal-group-sort-value="<%= @group_sort %>"
  data-meeting-upload-modal-open-value="<%= @open_upload_modal %>"
>
  <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold"><%= @project.name %></h1>
      <p class="text-sm text-[var(--mi-text-secondary)]"><%= @project.description %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit", edit_project_path(@project), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-2 text-sm" %>
      <%= link_to "Cross-meeting chat", project_chat_sessions_path(@project), class: "rounded-[8px] border border-[var(--mi-border)] px-3 py-2 text-sm" %>
      <button
        type="button"
        class="rounded-[8px] bg-[var(--mi-teal)] px-4 py-2 text-sm font-medium text-[#0f0f0f]"
        data-action="click->meeting-upload-modal#openModal"
      >
        Upload meeting
      </button>
      <%= button_to "Delete project",
            project_path(@project),
            method: :delete,
            class: "rounded-[8px] border border-[var(--mi-red)] px-3 py-2 text-sm text-[var(--mi-red)]",
            form: { data: { turbo_confirm: "Delete this project and all its meetings?" } } %>
    </div>
  </div>

  <%= form_with url: project_path(@project), method: :get, class: "flex flex-wrap items-end gap-3" do %>
    <div>
      <label class="block text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)]">Group by</label>
      <%= select_tag :group,
            options_for_select(
              [
                [ "Meeting name", "title" ],
                [ "Day", "day" ],
                [ "Week", "week" ],
                [ "Month", "month" ]
              ],
              @group
            ),
            class: "mt-1 rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-surface)] px-3 py-2 text-sm",
            onchange: "this.form.requestSubmit()" %>
    </div>
    <div>
      <label class="block text-xs font-mono-mi uppercase text-[var(--mi-text-secondary)]">Sort groups</label>
      <%= select_tag :group_sort,
            options_for_select(
              [
                [ "Latest meeting first", "latest" ],
                [ "Name / period (A–Z)", "name" ]
              ],
              @group_sort
            ),
            class: "mt-1 rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-surface)] px-3 py-2 text-sm",
            onchange: "this.form.requestSubmit()" %>
    </div>
  <% end %>

  <%= render "projects/meeting_groups",
      project: @project,
      grouped: @grouped,
      group: @group,
      group_sort: @group_sort %>

  <dialog
    data-meeting-detail-target="dialog"
    class="fixed left-1/2 top-1/2 z-50 w-[min(100vw-2rem,960px)] max-h-[min(100vh-2rem,92vh)] -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-2xl border border-[var(--mi-border)] bg-[var(--mi-surface)] p-0 shadow-[0_24px_80px_-16px_rgba(0,0,0,0.55)] backdrop:bg-black/65 backdrop:backdrop-blur-sm"
    aria-label="Meeting details"
  >
    <div class="flex max-h-[min(100vh-2rem,92vh)] flex-col">
      <div
        class="flex shrink-0 items-center justify-between gap-3 border-b border-[var(--mi-border)] bg-gradient-to-r from-[var(--mi-bg)]/40 via-[var(--mi-surface)] to-[var(--mi-surface)] px-4 py-3"
      >
        <p class="text-[11px] font-mono-mi font-medium uppercase tracking-[0.12em] text-[var(--mi-text-secondary)]">
          Preview
        </p>
        <button
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--mi-border)] bg-[var(--mi-surface)] text-[var(--mi-text)] transition-colors hover:border-[var(--mi-teal)]/40 hover:bg-[var(--mi-teal)]/[0.06] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--mi-teal)]/40 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--mi-surface)]"
          data-action="click->meeting-detail#close"
          aria-label="Close preview"
        >
          <%= render "shared/mi_icon", name: :close, class: "h-5 w-5" %>
        </button>
      </div>
      <div
        class="min-h-0 flex-1 overflow-y-auto bg-[var(--mi-bg)]/20 p-4 md:p-5 [scrollbar-width:thin] [scrollbar-color:var(--mi-border)_transparent]"
      >
        <turbo-frame
          id="meeting-detail"
          data-meeting-detail-target="frame"
          class="block min-h-[200px]"
        ></turbo-frame>
      </div>
    </div>
  </dialog>

  <%= render "projects/upload_meeting_modal" %>
</div>
