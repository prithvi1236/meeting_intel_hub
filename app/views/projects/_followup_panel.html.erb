<%# locals: (project:) %>
<%
  open_items = ExtractedItem.action_items.open
    .joins(:meeting)
    .where(meetings: { project_id: project.id })
  pending_drafts_count = project.followup_drafts.pending_review.count

  groups = open_items.group_by { |i| i.owner.presence || t("followup.unassigned_assignee") }
%>

<div id="project-followup-panel" class="rounded-xl border border-[var(--mi-border)] bg-[var(--mi-surface)]/40 p-4 shadow-sm">
  <div class="flex flex-wrap items-center justify-between gap-2">
    <h2 class="text-xs font-mono-mi font-semibold uppercase tracking-wider text-[var(--mi-text)]/90">
      <%= t("followup.panel.open_items_title") %> (<%= open_items.size %>)
    </h2>
    <%= link_to t("followup.email_book.manage_link"),
                project_project_assignee_contacts_path(project),
                class: "rounded text-xs font-medium text-[var(--mi-teal)] hover:underline focus:outline-none focus:ring-2 focus:ring-[var(--mi-teal)]/50" %>
  </div>

  <div class="mt-3 flex flex-wrap items-center gap-2 text-xs">
    <span class="rounded-full border border-[var(--mi-border)] px-2 py-1 text-[var(--mi-text-secondary)]">
      <%= t("followup.summary.drafts_pending_count", count: pending_drafts_count) %>
    </span>
  </div>

  <div class="mt-4 border-t border-[var(--mi-border)]/70 pt-4">
    <% if open_items.empty? %>
      <div class="flex items-center justify-center rounded-lg border border-dashed border-[var(--mi-border)] bg-[var(--mi-bg)]/30 py-5">
        <p class="text-sm font-medium text-[var(--mi-text-secondary)]"><%= t("followup.panel.no_open_items") %></p>
      </div>
    <% else %>
      <div class="flex flex-wrap items-center gap-3">
        <%= button_to t("followup.panel.generate_all"),
              project_project_followup_drafts_generate_path(project),
              method: :post,
              class: "inline-flex items-center justify-center rounded-lg bg-[var(--mi-teal)] px-4 py-2 text-sm font-medium text-[#0f0f0f] shadow-sm hover:bg-[var(--mi-teal)]/90 focus:outline-none focus:ring-2 focus:ring-[var(--mi-teal)] focus:ring-offset-2 focus:ring-offset-[var(--mi-surface)]" %>

        <%= link_to t("followup.summary.review_project_link"),
                    project_followup_drafts_path(project),
                    class: "text-sm font-medium text-[var(--mi-teal)] hover:underline focus:outline-none focus:ring-2 focus:ring-[var(--mi-teal)]/50" %>
      </div>

      <details class="group mt-4 rounded-lg border border-[var(--mi-border)] bg-[var(--mi-bg)]/30">
        <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2.5 text-sm font-medium text-[var(--mi-text)] outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-[var(--mi-teal)] [&::-webkit-details-marker]:hidden">
          <span><%= t("followup.panel.per_assignee_heading") %></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[var(--mi-text-secondary)] transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>

        <div class="space-y-2 rounded-b-lg border-t border-[var(--mi-border)]/60 bg-[var(--mi-surface)]/20 p-3">
          <% groups.each do |label, items| %>
            <% key = followup_assignee_normalized_key(items.first) %>
            <div class="rounded-lg border border-[var(--mi-border)] bg-[var(--mi-surface)]/60 p-3">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div class="flex items-center gap-2 text-sm text-[var(--mi-text)]">
                  <%= label %>
                  <span class="inline-flex items-center rounded-full border border-[var(--mi-border)]/50 bg-[var(--mi-bg)] px-1.5 py-0.5 text-[10px] font-medium leading-none text-[var(--mi-text-secondary)]">
                    <%= t("followup.panel.items_count", count: items.size) %>
                  </span>
                </div>
                <%= button_to t("followup.panel.generate_for_assignee"),
                      project_project_followup_drafts_generate_path(project),
                      method: :post,
                      params: { assignee_normalized: key },
                      class: "inline-flex items-center rounded-md border border-[var(--mi-border)] bg-[var(--mi-bg)]/50 px-2.5 py-1 text-xs font-medium text-[var(--mi-text)] shadow-sm hover:text-[var(--mi-teal)] focus:outline-none focus:ring-2 focus:ring-[var(--mi-teal)]" %>
              </div>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
</div>