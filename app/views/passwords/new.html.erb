<% content_for :title, "Forgot password" %>
<div class="mx-auto w-full max-w-md">
  <% if alert = flash[:alert] %>
    <p class="mb-5 rounded-xl border border-[var(--mi-red)]/40 bg-[var(--mi-red)]/10 px-4 py-3 text-sm text-[var(--mi-red)]" id="alert" role="alert"><%= alert %></p>
  <% end %>

  <h1 class="mb-6 text-2xl font-semibold">Forgot your password?</h1>

  <%= form_with url: passwords_path, class: "space-y-4" do |form| %>
    <div>
      <%= label_tag :email, "Email", class: "block text-sm text-[var(--mi-text-secondary)]" %>
      <%= email_field_tag :email, params[:email], required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your email address", class: "mt-1 w-full rounded-[8px] border border-[var(--mi-border)] bg-[var(--mi-bg)] px-3 py-2 text-sm" %>
    </div>

    <%= form.submit "Email reset instructions", class: "cursor-pointer rounded-[8px] bg-[var(--mi-teal)] px-4 py-2 text-sm font-medium text-[#0f0f0f]" %>
  <% end %>
</div>
